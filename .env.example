# =============================================================================
# API
# =============================================================================
# Porta em que o servidor irá rodar
PORT=3010

# Porta do frontend utilizada no docker-compose
FRONTEND_PORT=3001

# Ambiente da aplicação (development/test/production)
NODE_ENV=development

# Ativa/desativa logs detalhados (true/false)
DEBUGLOG=true

# =============================================================================
# BANCO DE DADOS
# =============================================================================
# URL de conexão com o banco MongoDB
# Exemplos:
#   Local:  mongodb://localhost:27017/estoque-inteligente
#   Atlas:  mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/estoque-inteligente?retryWrites=true&w=majority
#   Docker: mongodb://mongodb:27017/estoque-inteligente (configurado no docker-compose)
DB_URL=mongodb://localhost:27017/estoque-inteligente

# URL de conexão com o banco de testes (opcional)
DB_URL_TEST=mongodb://localhost:27017/estoque-inteligente-test

# =============================================================================
# JWT
# =============================================================================
# Secrets para autenticação JWT
JWT_SECRET_ACCESS_TOKEN=GERE_UMA_CHAVE_SECRETA
JWT_SECRET_REFRESH_TOKEN=GERE_UMA_CHAVE_SECRETA
JWT_SECRET_PASSWORD_RECOVERY=GERE_UMA_CHAVE_SECRETA
JWT_SECRET_INVITE=GERE_UMA_CHAVE_SECRETA

# Tempo de expiração dos tokens JWT
# Formatos aceitos: s (segundos), m (minutos), h (horas), d (dias)
JWT_ACCESS_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_EXPIRATION=7d

# =============================================================================
# SERVIÇO DE E-MAIL
# =============================================================================
# Configurar conta Google para envio de e-mails:
# 1) Acesse https://myaccount.google.com/security e habilite 2-step verification
# 2) Acesse https://myaccount.google.com/apppasswords e gere uma senha de app
# 3) Use o e-mail do Google e a senha de app gerada

# E-mail que será usado para enviar os e-mails (Gmail)
EMAIL_USER=seu_email@gmail.com

# Senha de aplicativo gerada (Gmail)
EMAIL_APP_PASSWORD=sua_senha_de_app_aqui

# Nome da empresa (aparecerá no remetente dos e-mails)
COMPANY_NAME=Estoque Inteligente

# URL do frontend (para gerar links nos e-mails)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# MINIO
# =============================================================================
# Endpoint
MINIO_ENDPOINT=localhost

# Porta da API
MINIO_PORT=9000

# Porta do console web
MINIO_CONSOLE_PORT=9001

# Credenciais de acesso
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Buckets
MINIO_BUCKET=usuarios
MINIO_BUCKET_2=itens

# URL pública para acesso via navegador
MINIO_PUBLIC_URL=http://localhost:9000

# =============================================================================
# USUÁRIO ADMINISTRADOR
# =============================================================================
# Dados do usuário administrador que será criado nas seeds
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=Senha@123
